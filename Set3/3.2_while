# exercise_3_2_while.py
x = 1
while x <= 40:
    if x == 13:
        x += 1
        continue
    if x % 5 == 0 and x % 7 == 0:
        print(f"{x} is divided by 5 and 7")
    elif x % 5 == 0:
        print(f"{x} is divided by 5")
    elif x % 7 == 0:
        print(f"{x} is divided by 7")
    else:
        print(f"{x} is not important")
    x += 1
