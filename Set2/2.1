# EXERCISE 2.1: Count zeros in a long positive integer

# Define a long positive integer
long_number = 10203040506070809000

# Convert the number to a string
number_str = str(long_number)

# Count the zeros using the count() method
zero_count = number_str.count('0')

# Print the results
print(f"Number: {long_number}")
print(f"Number of zeros: {zero_count}")
