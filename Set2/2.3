# EXERCISE 2.3 (NUMBERS): Sum of squares of odd numbers (1*1 + 3*3 + ... + 2027*2027)

# Create a range of odd numbers from 1 to 2027 (step 2)
odd_numbers = range(1, 2028, 2)

# Calculate the sum of squares using a generator expression inside sum()
total_sum = sum(n * n for n in odd_numbers)

# Print the result
print(f"The sum of squares of odd numbers from 1 to 2027 is: {total_sum}")
