# EXERCISE 2.7 (DICT): Create a dict for roman numeral conversion

# Method 1: Direct dictionary creation
roman_to_arabic_1 = {
    'I': 1,
    'IV': 4,
    'V': 5,
    'IX': 9,
    'X': 10,
    'XL': 40,
    'L': 50,
    'XC': 90,
    'C': 100,
    'CD': 400,
    'D': 500,
    'CM': 900,
    'M': 1000
}
print("Method 1 Dictionary:")
print(roman_to_arabic_1)

# Method 2: Using zip() with parallel lists
roman_symbols = ['I', 'IV', 'V', 'IX', 'X', 'XL', 'L', 'XC', 'C', 'CD', 'D', 'CM', 'M']
arabic_values = [1, 4, 5, 9, 10, 40, 50, 90, 100, 400, 500, 900, 1000]
roman_to_arabic_2 = dict(zip(roman_symbols, arabic_values))
print("\nMethod 2 Dictionary:")
print(roman_to_arabic_2)

# Example usage: Convert a simple Roman numeral
test_roman = 'X'
print(f"\nThe value of '{test_roman}' is: {roman_to_arabic_1[test_roman]}")
